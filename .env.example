# Supabase — from your project's API settings
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Prisma — Supabase Postgres connection string (use the pooled 6543 port for the app,
# and the direct 5432 port for migrations)
DATABASE_URL="postgresql://postgres.your-ref:password@aws-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.your-ref:password@aws-region.pooler.supabase.com:5432/postgres"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
